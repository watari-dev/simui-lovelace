{
  "name": "simui-lovelace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "SimUI Cards — a set of minimalist, Apple-Home-inspired custom Lovelace cards for Home Assistant.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "build:hacs": "npm run build && node -e \"require('fs').mkdirSync('dist',{recursive:true})\""
  },
  "dependencies": {
    "lucide-react": "^0.456.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  }
}
